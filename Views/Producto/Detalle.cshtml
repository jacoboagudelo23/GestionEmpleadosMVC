@model GestionEmpleadosMVC.Models.Producto

<div class="container mt-5">
    <div class="card shadow-lg border-0 p-4 rounded-4">
        <div class="row align-items-center">
            <div class="col-md-6 text-center">
                <img src="@Model.ImagenUrl"
                     class="img-fluid detail-img"
                     alt="@Model.Nombre"
                     onerror="this.src='https://placehold.co/400x260/e9ecef/adb5bd?text=Sin+imagen'" />
            </div>
            <div class="col-md-6">
                <h1 class="fw-bold text-dark">@Model.Nombre</h1>
                <p class="badge bg-primary fs-6">@Model.Categoria</p>
                <hr>
                <p class="lead">@Model.Descripcion</p>
                <p><strong>Especificaciones:</strong> @Model.Especificaciones</p>
                <h2 class="text-success fw-bold mt-4">$@Model.Precio.ToString("N0")</h2>

                <div class="mt-4 d-flex gap-3">
                    <!-- BOTÓN VOLVER -->
                    <a asp-action="Index" class="btn btn-outline-dark btn-lg rounded-pill px-4">
                        Volver
                    </a>

                    <!-- BOTÓN PAGAR -->
                    <a asp-action="ConfirmacionPago" class="btn btn-dark btn-lg rounded-pill px-4 shadow">
                        Pagar Ahora
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>