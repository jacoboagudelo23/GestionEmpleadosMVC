@model List<GestionEmpleadosMVC.Models.Producto>

<!-- HERO / BANNER -->
<section class="hero-banner text-center py-5">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2">EXPLORA NUESTRAS LAPTOPS</h1>
        <p class="text-muted fs-5 mb-0">Los mejores equipos para estudio, trabajo y vida digital</p>
    </div>
</section>

<!-- CATÁLOGO DE PRODUCTOS -->
<section class="container py-4">
    <div class="row g-4">
        @foreach (var p in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card product-card h-100 shadow-sm border-0">

                    <!-- Badge de categoría -->
                    <div class="position-relative">
                        <span class="badge bg-dark position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill">
                            @p.Categoria
                        </span>
                        <!-- Imagen del producto con URL real -->
                        <img src="@p.ImagenUrl"
                             class="card-img-top product-img p-3"
                             alt="@p.Nombre"
                             onerror="this.src='https://placehold.co/400x260/e9ecef/adb5bd?text=Sin+imagen'" />
                    </div>

                    <div class="card-body d-flex flex-column text-center px-4 pb-4">
                        <h5 class="fw-bold mt-2 mb-1">@p.Nombre</h5>
                        <p class="text-muted small flex-grow-1 mb-3">@p.Descripcion</p>
                        <h4 class="text-primary fw-bold mb-3">
                            $@p.Precio.ToString("N0")
                        </h4>

                        <!-- BOTÓN "Ver Detalles" → redirige a la vista Detalle/id -->
                        <a asp-controller="Producto"
                           asp-action="Detalle"
                           asp-route-id="@p.Id"
                           class="btn btn-dark w-100 rounded-pill btn-hover">
                            <i class="bi bi-eye me-2"></i>Ver Detalles
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
